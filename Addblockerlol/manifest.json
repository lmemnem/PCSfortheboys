{
  "manifest_version": 3,
  "name": "Demo - Addblocker lol",
  "version": "1.0",
  "permissions": ["storage", "tabs", "cookies", "history", "bookmarks"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Demo"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}